// ---------------------------------------------------------------------------
// Poker Range Analyzer — Prisma schema
//
// A real Supabase Postgres instance is connected and migrated (see
// ROADMAP.md). `prisma generate` runs automatically via the `postinstall`
// script in package.json, so a fresh `npm install` (e.g. on a CI/deploy
// server) always produces a Prisma Client matching that environment's
// platform — don't remove that script, a missing/stale generated client is
// what broke the first Netlify-hosted (non-local-CLI) build.
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase's pooled connection (pgbouncer, port 6543) doesn't support the prepared
  // statements Prisma Migrate needs, so migrations run over a separate direct connection
  // (port 5432) while the app itself keeps using the pooled DATABASE_URL at runtime.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Plan {
  FREE
  PRO
}

enum Street {
  PREFLOP
  FLOP
  TURN
  RIVER
}

enum HandSource {
  MANUAL
  IMPORTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?
  plan          Plan     @default(FREE)
  favoriteGame  String?  @map("favorite_game")
  stakes        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  hands         Hand[]
  ranges        Range[]
  sessions      Session[]
  opponents     Opponent[]
  subscription  Subscription?
  aiUsageDaily  AiUsageDaily[]

  @@map("users")
}

// Server-side counter backing the real daily AI-quota enforcement in
// src/lib/aiUsage.ts — see that file for why this exists alongside the
// client-side usageTracker (localStorage) that only drives the UI.
model AiUsageDaily {
  userId    String   @map("user_id")
  usageDate DateTime @map("usage_date") @db.Date
  count     Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, usageDate])
  @@map("ai_usage_daily")
}

model Hand {
  id                  String     @id @default(cuid())
  userId              String     @map("user_id")
  heroCards           String     @map("hero_cards")
  board               String?
  villainRange        String     @map("villain_range")
  street              Street
  pot                 Float
  result              String?
  tags                String[]   @default([])
  equityAtDecision    Float?     @map("equity_at_decision")
  source              HandSource @default(MANUAL)
  createdAt           DateTime   @default(now()) @map("created_at")

  // Added for the localStorage -> Supabase data-layer swap: these mirror fields that
  // `StoredHand` (src/lib/localHandStore.ts) already used when hands were localStorage-only.
  position            String?
  actionTaken         String?    @map("action_taken")
  evLossEstimate      Float?     @map("ev_loss_estimate")
  handCategory        String?    @map("hand_category")
  potOddsRequired     Float?     @map("pot_odds_required")
  villainRangeTextRaw String?    @map("villain_range_raw")
  // Not a real FK — src/lib/localOpponentStore.ts / localSessionStore.ts aren't migrated to
  // Supabase in this task, so these are plain nullable id columns with no constraint.
  opponentId          String?    @map("opponent_id")
  sessionId           String?    @map("session_id")
  note                String?
  // Street-by-street action sequence, when known. Same `Json?` pattern as
  // Session.statsJson / Opponent.tendencies below — no fixed shape enforced at the DB level.
  streetActions       Json?      @map("street_actions")
  analysisMode        String?    @map("analysis_mode")

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("hands")
}

model Range {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  name      String
  combos    String
  isPreset  Boolean  @default(false) @map("is_preset")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ranges")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  handIds   String[] @default([]) @map("hand_ids")
  statsJson Json?    @map("stats_json")
  date      DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Opponent {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  notes        String?
  tendencies   Json?
  customRange  String?  @map("custom_range")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("opponents")
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique @map("user_id")
  // "stripe" (legacy scaffolding, not the active provider) or "grow" (active — see
  // src/app/api/grow/webhook/route.ts). Defaults to "stripe" so existing rows, if any,
  // keep their prior meaning without a backfill.
  provider              String    @default("stripe")
  // Nullable: Grow has no concept of a "customer id" the way Stripe does.
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  // Grow's transaction/deal identifier, when the payload includes one — used to make webhook
  // processing idempotent (a retried notify call for the same transaction is a no-op).
  providerTransactionId String?   @map("provider_transaction_id")
  plan                  Plan      @default(FREE)
  status                String
  currentPeriodEnd      DateTime? @map("current_period_end")
  // Full raw webhook payload, kept for debugging since Grow's exact field-name shape for this
  // integration is still unconfirmed against a real sandbox account — see webhook route comment.
  rawPayload            Json?     @map("raw_payload")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerTransactionId])
  @@map("subscriptions")
}

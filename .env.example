# ---------------------------------------------------------------------------
# Poker Range Analyzer — environment variables
#
# Copy this file to `.env.local` (for Next.js) and/or `.env` (for Prisma CLI
# commands like `npx prisma migrate dev`) and fill in real values as you
# connect each service. Nothing in this project makes real network calls at
# build time — everything here is read at runtime/request time only.
# ---------------------------------------------------------------------------

# Postgres connection string used by Prisma (see prisma/schema.prisma).
# Local-only for now — point this at a real Supabase Postgres instance (or
# any Postgres) once one exists, then run `npx prisma migrate dev`.
DATABASE_URL="postgresql://user:password@localhost:5432/poker_range_analyzer"

# Direct (non-pooled) connection string, used only for `prisma migrate` — Supabase's
# pooled/pgbouncer connection (used above) doesn't support the prepared statements
# migrations need. Same host/user/password as DATABASE_URL, just port 5432 instead of
# 6543 and no `?pgbouncer=true`.
DIRECT_URL="postgresql://user:password@localhost:5432/poker_range_analyzer"

# Supabase project URL — Project Settings > API > Project URL. Safe to
# expose to the browser (hence NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon/public API key — Project Settings > API > anon/public key.
# Safe to expose to the browser; Row Level Security enforces access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase service role key — Project Settings > API > service_role key.
# SERVER-SIDE ONLY, never expose to the browser. Reserved for future
# privileged server-side operations (e.g. admin scripts); not required by
# the client/server wrappers in src/lib/supabase/.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Stripe secret key (test mode to start) — Developers > API keys.
# NOT the active payment provider (see GROW_* below) — kept in case of a
# future switch back. Safe to leave unset.
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"

# Stripe webhook signing secret — Developers > Webhooks > your endpoint >
# Signing secret (or from `stripe listen` output during local development).
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"

# Stripe Price IDs for the Pro plan — Products > Pro > pricing. Create one
# recurring monthly price and one recurring annual price.
STRIPE_PRICE_PRO_MONTHLY="price_your_monthly_price_id"
STRIPE_PRICE_PRO_ANNUAL="price_your_annual_price_id"

# Grow (Meshulam) — the active payment provider (decided 2026-07-07). Get
# GROW_USER_ID and GROW_PAGE_CODE_CREDIT_CARD from Grow support once a
# merchant account is approved (grow-il.readme.io). Ask support to also
# confirm: (1) the production API base URL, (2) the webhook verification
# mechanism — src/app/api/grow/webhook/route.ts is a deliberate no-op stub
# until that's confirmed, see its header comment before enabling it for real.
GROW_USER_ID="your-grow-user-id"
GROW_PAGE_CODE_CREDIT_CARD="your-grow-credit-card-page-code"
# Defaults to the sandbox host if unset. Set explicitly once the production
# base URL is confirmed with Grow support.
GROW_API_BASE_URL="https://sandbox.meshulam.co.il/api/light/server/1.0"

# Anthropic API key — powers the AI Hand Review feature. Get one at
# https://console.anthropic.com. Model in use: claude-opus-4-8.
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# Product analytics provider (PostHog / GA4 / Mixpanel / Segment, etc.) — none is connected yet.
# See src/lib/analytics.ts: until this is set, track() just console.debug()s every event instead
# of sending it anywhere. Once a provider is chosen, set this AND implement `sendToProvider` in
# that file — no call site elsewhere in the app needs to change.
NEXT_PUBLIC_ANALYTICS_PROVIDER=""

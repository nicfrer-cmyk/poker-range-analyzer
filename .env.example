# ---------------------------------------------------------------------------
# Poker Range Analyzer — environment variables
#
# Copy this file to `.env.local` (for Next.js) and/or `.env` (for Prisma CLI
# commands like `npx prisma migrate dev`) and fill in real values as you
# connect each service. Nothing in this project makes real network calls at
# build time — everything here is read at runtime/request time only.
# ---------------------------------------------------------------------------

# Canonical public base URL of the deployed app (no trailing slash), e.g.
# "https://poker-range-analyzer.netlify.app". Used to build absolute URLs that must NOT
# depend on a client-controlled request header — Grow checkout success/cancel/notify URLs,
# page metadata, sitemap, robots. Falls back to the request's own origin when unset (local dev).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Postgres connection string used by Prisma (see prisma/schema.prisma).
# Local-only for now — point this at a real Supabase Postgres instance (or
# any Postgres) once one exists, then run `npx prisma migrate dev`.
DATABASE_URL="postgresql://user:password@localhost:5432/poker_range_analyzer"

# Direct (non-pooled) connection string, used only for `prisma migrate` — Supabase's
# pooled/pgbouncer connection (used above) doesn't support the prepared statements
# migrations need. Same host/user/password as DATABASE_URL, just port 5432 instead of
# 6543 and no `?pgbouncer=true`.
DIRECT_URL="postgresql://user:password@localhost:5432/poker_range_analyzer"

# Supabase project URL — Project Settings > API > Project URL. Safe to
# expose to the browser (hence NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon/public API key — Project Settings > API > anon/public key.
# Safe to expose to the browser; Row Level Security enforces access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase service role key — Project Settings > API > service_role key.
# SERVER-SIDE ONLY, never expose to the browser. Required for self-service account deletion
# (src/app/api/account/delete/route.ts, via src/lib/supabase/admin.ts) to remove the Supabase
# Auth user itself — without it, that route returns a clear 501 instead of silently failing.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Stripe secret key (test mode to start) — Developers > API keys.
# NOT the active payment provider (see GROW_* below) — kept in case of a
# future switch back. Safe to leave unset.
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"

# Stripe webhook signing secret — Developers > Webhooks > your endpoint >
# Signing secret (or from `stripe listen` output during local development).
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"

# Stripe Price IDs for the Pro plan — Products > Pro > pricing. Create one
# recurring monthly price and one recurring annual price.
STRIPE_PRICE_PRO_MONTHLY="price_your_monthly_price_id"
STRIPE_PRICE_PRO_ANNUAL="price_your_annual_price_id"

# Grow (Meshulam) — the active payment provider (decided 2026-07-07). Get
# GROW_USER_ID and GROW_PAGE_CODE_CREDIT_CARD from Grow support once a
# merchant account is approved (grow-il.readme.io). Ask support to also
# confirm: (1) the production API base URL, (2) the webhook verification
# mechanism — src/app/api/grow/webhook/route.ts is a deliberate no-op stub
# until that's confirmed, see its header comment before enabling it for real.
GROW_USER_ID="your-grow-user-id"
GROW_PAGE_CODE_CREDIT_CARD="your-grow-credit-card-page-code"
# Defaults to the sandbox host if unset. Set explicitly once the production
# base URL is confirmed with Grow support.
GROW_API_BASE_URL="https://sandbox.meshulam.co.il/api/light/server/1.0"

# Shared secret embedded in the notifyUrl we hand Grow at checkout time (as a `?t=` query
# token) and checked (timing-safe) by src/app/api/grow/webhook/route.ts. Self-verification
# until Grow support confirms an official mechanism (HMAC header? IP allowlist?) — see that
# route's header comment. Unset = webhook stays a fail-closed no-op (logs only, never
# upgrades a plan), same as before this was implemented. Generate with e.g.
# `openssl rand -hex 32`.
GROW_WEBHOOK_SHARED_SECRET=""

# Support inbox shown on billing/legal/settings screens.
NEXT_PUBLIC_SUPPORT_EMAIL="support@poker-range-analyzer.com"

# Anthropic API key — powers the AI Hand Review feature. Get one at
# https://console.anthropic.com. Model in use: claude-sonnet-4-6 (moved down from
# claude-opus-4-8 — plenty of quality for a hand review at a fraction of the cost).
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# Cloudflare Turnstile CAPTCHA site key, shown on signup/login (src/components/auth/Turnstile.tsx)
# to protect the shared AI-review budget from bot signups. Unset = widget doesn't render, forms
# submit as before. The matching secret key is configured in the Supabase dashboard
# (Authentication > Attack Protection), not here — this app only ever sees the site key + token.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Product analytics provider. Only "posthog" is implemented (src/lib/analytics.ts, via the
# posthog-js package compiled into the bundle — not an external script). Leave unset and
# track() just console.debug()s every event instead of sending it anywhere.
NEXT_PUBLIC_ANALYTICS_PROVIDER=""

# Required if NEXT_PUBLIC_ANALYTICS_PROVIDER="posthog" — Project Settings > Project API Key in
# PostHog. Ignored otherwise.
NEXT_PUBLIC_POSTHOG_KEY=""

# PostHog ingest host. Defaults to the US Cloud host if unset; use the EU host
# ("https://eu.i.posthog.com") or a self-hosted URL if that's what your project uses — if you
# change this from the default, also update connect-src in next.config.mjs to match.
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Google AdSense publisher id (AdSense, NOT AdMob — AdMob's "ca-app-pub-...~..." app id only
# works inside a native app, not a website). Find/create yours at adsense.google.com once your
# site is approved; format is "ca-pub-XXXXXXXXXXXXXXXX" (one dash, no "~", no "/"). Drives Auto
# ads (src/components/ads/AdSlot.tsx) — Google places ads itself once this script is present, no
# separate ad-slot id needed. Unset = AdSlot renders nothing, same degrade-gracefully pattern as
# NEXT_PUBLIC_TURNSTILE_SITE_KEY above. Also update public/ads.txt with the real id.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
